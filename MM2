local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local ESPEnabled = true
local LockEnabled = false
local CurrentTarget = nil 

local UseStrictCamlock = false 

local ProjectileSpeed = 1000 
local MaxPredictionCap = 0.16
local PredictionMultiplier = 0.95
local WorkspaceGravity = 196.2
local YHistoryMax = 12

local ESP = {}
local TargetHistory = {}
local RoleCache = {}

local GunDropMarker = nil
local GunDropHighlight = nil
local GunDropLabel = nil

local LastSheriffPos = nil
local FallbackSheriffMarker = nil
local HadSheriffBefore = false

local AutoShootActive = false
local AutoShootTimer = 0

local function IsAimingMode()
    return UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter or (Camera.Focus.Position - Camera.CFrame.Position).Magnitude < 1.0
end

local function UpdatePlayerRoles()
    local newRoles = {}
    for _, player in ipairs(Players:GetPlayers()) do
        local isSheriff = false
        local isMurderer = false
        
        local char = player.Character
        local bp = player:FindFirstChild("Backpack")
        
        if (bp and bp:FindFirstChild("Gun")) or (char and char:FindFirstChild("Gun")) then
            isSheriff = true
        end
        
        if (bp and bp:FindFirstChild("Knife")) or (char and char:FindFirstChild("Knife")) then
            isMurderer = true
        end
        
        newRoles[player] = {Sheriff = isSheriff, Murderer = isMurderer}
    end
    RoleCache = newRoles
end

local function IsSheriff(player)
    local data = RoleCache[player]
    return data and data.Sheriff or false
end

local function IsMurderer(player)
    local data = RoleCache[player]
    return data and data.Murderer or false
end

local function GetColor(player)
    if IsMurderer(player) then
        return Color3.fromRGB(255, 70, 70)
    elseif IsSheriff(player) then
        return Color3.fromRGB(80, 120, 255)
    end
    return Color3.fromRGB(80, 255, 120)
end

local function CreateESP(player)
    if ESP[player] then return ESP[player] end

    local highlight = Instance.new("Highlight")
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillTransparency = 1
    highlight.OutlineTransparency = 0

    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 100, 0, 20)
    billboard.StudsOffset = Vector3.new(0, 2.2, 0)
    billboard.AlwaysOnTop = true

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextSize = 14
    label.Font = Enum.Font.GothamBold
    label.TextStrokeTransparency = 0.5
    label.TextScaled = false
    label.Parent = billboard

    ESP[player] = {
        highlight = highlight,
        gui = billboard,
        label = label
    }

    return ESP[player]
end

local function RemoveESP(player)
    if ESP[player] then
        if ESP[player].highlight then ESP[player].highlight:Destroy() end
        if ESP[player].gui then ESP[player].gui:Destroy() end
        ESP[player] = nil
    end
    if CurrentTarget == player then
        CurrentTarget = nil
        LockEnabled = false
    end
    TargetHistory[player] = nil
    RoleCache[player] = nil
end

local function CreateGunDropVisuals(gunDropInstance)
    local yellowColor = Color3.fromRGB(255, 230, 0)

    local highlight = Instance.new("Highlight")
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillColor = yellowColor
    highlight.FillTransparency = 0.85 
    highlight.OutlineColor = yellowColor
    highlight.OutlineTransparency = 0
    highlight.Adornee = gunDropInstance
    highlight.Parent = gunDropInstance
    GunDropHighlight = highlight

    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 150, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 2, 0) 
    billboard.AlwaysOnTop = true
    billboard.Adornee = gunDropInstance
    billboard.Parent = gunDropInstance

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextSize = 14
    label.Font = Enum.Font.GothamBlack
    label.TextColor3 = yellowColor
    label.TextStrokeTransparency = 0.2
    label.Parent = billboard
    GunDropLabel = label

    GunDropMarker = gunDropInstance
end

local function ClearGunDropVisuals()
    if GunDropHighlight then GunDropHighlight:Destroy() GunDropHighlight = nil end
    if GunDropLabel then GunDropLabel.Parent:Destroy() GunDropLabel = nil end 
    GunDropMarker = nil
end

local function FindDroppedGun()
    for _, obj in ipairs(workspace:GetChildren()) do
        if (obj.Name == "GunDrop" or obj.Name == "Gun") and (obj:IsA("BasePart") or obj:IsA("Model")) then
            local isHeld = false
            for _, player in ipairs(Players:GetPlayers()) do
                if player.Character and obj:IsDescendantOf(player.Character) then
                    isHeld = true
                    break
                end
            end
            if not isHeld and not obj:IsDescendantOf(Camera) then
                return obj
            end
        end
        
        if obj:IsA("Folder") or obj:IsA("Model") then
            for _, subObj in ipairs(obj:GetChildren()) do
                if (subObj.Name == "GunDrop" or subObj.Name == "Gun") and (subObj:IsA("BasePart") or subObj:IsA("Model")) then
                    local isHeld = false
                    for _, player in ipairs(Players:GetPlayers()) do
                        if player.Character and subObj:IsDescendantOf(player.Character) then
                    isHeld = true
                    break
                        end
                    end
                    if not isHeld and not subObj:IsDescendantOf(Camera) then
                        return subObj
                    end
                end
            end
        end
    end
    return nil
end

local function GetSheriff()
    for _, p in ipairs(Players:GetPlayers()) do
        if IsSheriff(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            return p
        end
    end
    return nil
end

local function CreateFallbackMarker(pos)
    if FallbackSheriffMarker then
        FallbackSheriffMarker:Destroy()
    end

    local part = Instance.new("Part")
    part.Anchored = true
    part.CanCollide = false
    part.Transparency = 1
    part.Size = Vector3.new(1,1,1)
    part.Position = pos
    part.Parent = workspace

    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.new(0, 60, 0, 60)
    gui.AlwaysOnTop = true
    gui.Parent = part

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,1,0)
    label.BackgroundTransparency = 1
    label.Text = "!"
    label.TextColor3 = Color3.fromRGB(255, 230, 0)
    label.TextStrokeTransparency = 0.2
    label.TextScaled = true
    label.Font = Enum.Font.GothamBlack
    label.Parent = gui

    FallbackSheriffMarker = part
end

local function GetBestAimPart(character)
    local priorityParts = {
        "HumanoidRootPart",
        "UpperTorso",
        "Torso",
        "Head"
    }
    for _, partName in ipairs(priorityParts) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            return part
        end
    end
    local limbParts = {
        "RightUpperArm", "LeftUpperArm", "RightLowerArm", "LeftLowerArm",
        "RightArm", "LeftArm", "RightHand", "LeftHand"
    }
    for _, partName in ipairs(limbParts) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            return part
        end
    end
    return nil
end

local function GetClosestPlayerToCrosshair()
    local bestTarget = nil
    local shortestDistance = math.huge

    local localHasGun = IsSheriff(LocalPlayer)
    local localHasKnife = IsMurderer(LocalPlayer)
    local localHasNothing = not localHasGun and not localHasKnife
    local mouseLocation = UserInputService:GetMouseLocation()

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") then
            local aimPart = GetBestAimPart(player.Character)
            if aimPart and player.Character.Humanoid.Health > 0 then
                
                local isValid = false
                if localHasGun then
                    if IsSheriff(player) or IsMurderer(player) then isValid = true end
                elseif localHasKnife or localHasNothing then
                    isValid = true
                end

                if isValid then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(aimPart.Position)
                    
                    if onScreen then
                        local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - mouseLocation).Magnitude
                        if screenDist < shortestDistance then
                            shortestDistance = screenDist
                            bestTarget = player
                        end
                    end
                end
            end
        end
    end
    return bestTarget
end

local function GetMurdererPlayer()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and IsMurderer(player) and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            return player
        end
    end
    return nil
end

local function GetOtherSheriffPlayer()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and IsSheriff(player) and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            return player
        end
    end
    return nil
end

local function GetWeightedYVelocity(history)
    local historySize = #history.yHistory
    if historySize == 0 then return 0 end
    
    local totalWeight = 0
    local weightedSum = 0
    
    for i = 1, historySize do
        local weight = i
        weightedSum = weightedSum + (history.yHistory[i] * weight)
        totalWeight = totalWeight + weight
    end
    
    return weightedSum / totalWeight
end

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end

    if input.KeyCode == Enum.KeyCode.P then
        ESPEnabled = not ESPEnabled
        if not ESPEnabled then
            ClearGunDropVisuals()
            if FallbackSheriffMarker then
                FallbackSheriffMarker:Destroy()
                FallbackSheriffMarker = nil
            end
        end
    end

    if input.KeyCode == Enum.KeyCode.Q then
        LockEnabled = not LockEnabled
        if LockEnabled then
            CurrentTarget = GetClosestPlayerToCrosshair()
            if not CurrentTarget then
                LockEnabled = false
            end
        else
            CurrentTarget = nil
        end
    end

    if input.KeyCode == Enum.KeyCode.E then
        if IsSheriff(LocalPlayer) and LocalPlayer.Character then
            UpdatePlayerRoles() 
            
            local targetPlayer = GetMurdererPlayer() or GetOtherSheriffPlayer()
            if not targetPlayer then
                targetPlayer = GetClosestPlayerToCrosshair()
            end
            
            if targetPlayer and targetPlayer.Character then
                local gun = LocalPlayer.Character:FindFirstChild("Gun")
                if not gun then
                    gun = LocalPlayer:FindFirstChild("Backpack") and LocalPlayer.Backpack:FindFirstChild("Gun")
                    if gun then gun.Parent = LocalPlayer.Character end
                end

                if gun then
                    CurrentTarget = targetPlayer
                    LockEnabled = true
                    AutoShootActive = true
                    AutoShootTimer = 0.25
                    
                    local aimPart = GetBestAimPart(targetPlayer.Character)
                    if aimPart and TargetHistory[targetPlayer] then
                        local currentCamPos = Camera.CFrame.Position
                        local targetPos = aimPart.Position
                        local distance = (targetPos - currentCamPos).Magnitude
                        
                        local travelTime = distance / ProjectileSpeed
                        local playerPing = LocalPlayer:GetNetworkPing()
                        
                        local pingWeight = math.clamp(1.6 - (playerPing * 4), 1.0, 1.5)
                        local networkLatency = (playerPing > 0) and (playerPing * pingWeight) or 0.04
                        
                        local history = TargetHistory[targetPlayer]
                        
                        local speedModifier = 1.0
                        local lateralSpeed = Vector3.new(history.vel.X, 0, history.vel.Z).Magnitude
                        if lateralSpeed > 16.5 then
                            speedModifier = math.clamp(1.0 + ((lateralSpeed - 16.5) * 0.02), 1.0, 1.15)
                        end
                        
                        local strafeScale = 1.0
                        if history.isStrafing then
                            strafeScale = 0.60
                        end
                        
                        local predictionTime = (networkLatency + travelTime) * PredictionMultiplier * speedModifier * strafeScale
                        
                        local dynamicCap = (playerPing > 0.08) and math.min(MaxPredictionCap, 0.13) or MaxPredictionCap
                        if lateralSpeed > 16.5 then dynamicCap = dynamicCap * 1.12 end
                        predictionTime = math.min(predictionTime, dynamicCap)
                        
                        if distance < 15 then
                            local closeScale = math.clamp((distance - 3) / 12, 0, 1)
                            predictionTime = predictionTime * closeScale
                        end
                        
                        local lateralVelocity = Vector3.new(history.vel.X, 0, history.vel.Z)
                        if lateralVelocity.Magnitude > 58 then
                            lateralVelocity = lateralVelocity.Unit * 58
                        end
                        
                        local instantPredictedPos
                        if history.isJumping then
                            local smoothedYVel = GetWeightedYVelocity(history)
                            local verticalOffset = (smoothedYVel * predictionTime) - (0.5 * WorkspaceGravity * predictionTime * predictionTime)
                            
                            if distance < 14 then
                                verticalOffset = verticalOffset * math.clamp((distance - 2) / 12, 0, 1)
                            end
                            if verticalOffset < -1.8 then
                                verticalOffset = -1.8
                            end
                            
                            instantPredictedPos = targetPos + lateralVelocity * predictionTime + Vector3.new(0, verticalOffset, 0)
                        else
                            local verticalVelocity = Vector3.new(0, history.vel.Y, 0)
                            if verticalVelocity.Y > 58 then verticalVelocity = Vector3.new(0, 58, 0)
                            elseif verticalVelocity.Y < -58 then verticalVelocity = Vector3.new(0, -58, 0) end
                            instantPredictedPos = targetPos + (lateralVelocity + verticalVelocity) * predictionTime
                        end
                        
                        Camera.CFrame = CFrame.new(currentCamPos, instantPredictedPos)
                        
                        local myRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if myRoot then
                            myRoot.CFrame = CFrame.new(myRoot.Position, Vector3.new(instantPredictedPos.X, myRoot.Position.Y, instantPredictedPos.Z))
                        end
                    end
                    
                    if gun and gun.Parent == LocalPlayer.Character and gun:IsA("Tool") then
                        gun:Activate()
                    end
                end
            end
        end
    end
end)

local CachedGunDrop = nil
task.spawn(function()
    while true do
        if ESPEnabled then
            UpdatePlayerRoles()
            
            if not CachedGunDrop or not CachedGunDrop.Parent then
                CachedGunDrop = FindDroppedGun()
            end
        else
            CachedGunDrop = nil
        end
        task.wait(0.5)
    end
end)

RunService.RenderStepped:Connect(function(deltaTime)

    if AutoShootActive then
        AutoShootTimer = AutoShootTimer - deltaTime
        if AutoShootTimer <= 0 then
            AutoShootActive = false
            LockEnabled = false
            CurrentTarget = nil
        end
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local aimPart = GetBestAimPart(player.Character)
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if aimPart then
                local data = CreateESP(player)
                local color = GetColor(player)
                local head = player.Character:FindFirstChild("Head")

                if data.highlight.Parent ~= player.Character then data.highlight.Parent = player.Character end
                if data.highlight.FillColor ~= color then data.highlight.FillColor = color end
                if data.highlight.OutlineColor ~= color then data.highlight.OutlineColor = color end
                if data.highlight.Enabled ~= ESPEnabled then data.highlight.Enabled = ESPEnabled end

                if head then
                    if data.gui.Parent ~= head then data.gui.Parent = head end
                    if data.gui.Adornee ~= head then data.gui.Adornee = head end
                    if data.gui.Enabled ~= ESPEnabled then data.gui.Enabled = ESPEnabled end
                end

                if data.label.Text ~= player.Name then data.label.Text = player.Name end
                if data.label.TextColor3 ~= color then data.label.TextColor3 = color end

                if not TargetHistory[player] then
                    TargetHistory[player] = {pos = aimPart.Position, vel = Vector3.zero, isJumping = false, isStrafing = false, yHistory = {}}
                else
                    local previousData = TargetHistory[player]
                    local dt = math.max(deltaTime, 0.001)
                    local rawVelocity = (aimPart.Position - previousData.pos) / dt
                    
                    if rawVelocity.Magnitude > 150 then
                        rawVelocity = Vector3.zero
                    end
                    
                    table.insert(previousData.yHistory, rawVelocity.Y)
                    if #previousData.yHistory > YHistoryMax then
                        table.remove(previousData.yHistory, 1)
                    end
                    
                    local velocityChange = rawVelocity - previousData.vel
                    
                    local isJumpingCheck = false
                    if humanoid and (humanoid.FloorMaterial == Enum.Material.Air or math.abs(rawVelocity.Y) > 5) then
                        isJumpingCheck = true
                    end
                    
                    local isStrafingCheck = false
                    if previousData.vel.Magnitude > 1 and rawVelocity.Magnitude > 1 then
                        local currentDir = Vector3.new(rawVelocity.X, 0, rawVelocity.Z).Unit
                        local oldDir = Vector3.new(previousData.vel.X, 0, previousData.vel.Z).Unit
                        local dotProduct = oldDir:Dot(currentDir)
                        
                        if dotProduct < -0.25 then
                            isStrafingCheck = true
                        elseif previousData.isStrafing and dotProduct > 0.85 then
                            isStrafingCheck = false
                        else
                            isStrafingCheck = previousData.isStrafing
                        end
                    end
                    
                    local smoothFactor = 0.07
                    if velocityChange.Magnitude > 2 then
                        smoothFactor = math.min(0.07 + (velocityChange.Magnitude * 0.008), 0.22)
                    end
                    
                    if isStrafingCheck then
                        smoothFactor = 0.015
                    end
                    
                    TargetHistory[player].pos = aimPart.Position
                    TargetHistory[player].vel = previousData.vel:Lerp(rawVelocity, smoothFactor)
                    TargetHistory[player].isJumping = isJumpingCheck
                    TargetHistory[player].isStrafing = isStrafingCheck
                end
            end
        end
    end

    if LockEnabled and CurrentTarget and CurrentTarget.Character then
        local char = CurrentTarget.Character
        local humanoid = char:FindFirstChild("Humanoid")
        local aimPart = GetBestAimPart(char)
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

        if aimPart and humanoid and humanoid.Health > 0 and TargetHistory[CurrentTarget] then
            local currentCamPos = Camera.CFrame.Position
            local targetPos = aimPart.Position
            local predictedPosition = targetPos

            local distance = (targetPos - currentCamPos).Magnitude
            
            if distance > 1 and not UseStrictCamlock then
                local travelTime = distance / ProjectileSpeed
                local playerPing = LocalPlayer:GetNetworkPing()
                
                local pingWeight = math.clamp(1.6 - (playerPing * 4), 1.0, 1.5)
                local networkLatency = (playerPing > 0) and (playerPing * pingWeight) or 0.04
                
                local history = TargetHistory[CurrentTarget]
                
                local speedModifier = 1.0
                local lateralSpeed = Vector3.new(history.vel.X, 0, history.vel.Z).Magnitude
                if lateralSpeed > 16.5 then
                    speedModifier = math.clamp(1.0 + ((lateralSpeed - 16.5) * 0.02), 1.0, 1.15)
                end
                
                local strafeScale = 1.0
                if history.isStrafing then
                    strafeScale = 0.45
                end
                
                local predictionTime = (networkLatency + travelTime) * PredictionMultiplier * speedModifier * strafeScale
                
                local dynamicCap = (playerPing > 0.08) and math.min(MaxPredictionCap, 0.13) or MaxPredictionCap
                if lateralSpeed > 16.5 then dynamicCap = dynamicCap * 1.12 end
                predictionTime = math.min(predictionTime, dynamicCap)
                
                if distance < 15 then
                    local closeScale = math.clamp((distance - 3) / 12, 0, 1)
                    predictionTime = predictionTime * closeScale
                end
                
                local lateralVelocity = Vector3.new(history.vel.X, 0, history.vel.Z)
                if lateralVelocity.Magnitude > 58 then
                    lateralVelocity = lateralVelocity.Unit * 58
                end
                
                if history.isJumping then
                    local smoothedYVel = GetWeightedYVelocity(history)
                    local verticalOffset = (smoothedYVel * predictionTime) - (0.5 * WorkspaceGravity * predictionTime * predictionTime)
                    
                    if distance < 14 then
                        verticalOffset = verticalOffset * math.clamp((distance - 2) / 12, 0, 1)
                    end
                    if verticalOffset < -1.8 then
                        verticalOffset = -1.8
                    end
                    
                    predictedPosition = targetPos + lateralVelocity * predictionTime + Vector3.new(0, verticalOffset, 0)
                else
                    local verticalVelocity = Vector3.new(0, history.vel.Y, 0)
                    if verticalVelocity.Y > 58 then verticalVelocity = Vector3.new(0, 58, 0)
                    elseif verticalVelocity.Y < -58 then verticalVelocity = Vector3.new(0, -58, 0) end
                    predictedPosition = targetPos + (lateralVelocity + verticalVelocity) * predictionTime
                end
            end
            
            Camera.CFrame = CFrame.new(currentCamPos, predictedPosition)
            
            if myRoot then
                local lookAtPos = Vector3.new(predictedPosition.X, myRoot.Position.Y, predictedPosition.Z)
                myRoot.CFrame = CFrame.new(myRoot.Position, lookAtPos)
            end

            if not IsAimingMode() then
                local screenPos, onScreen = Camera:WorldToViewportPoint(predictedPosition)
                if onScreen then
                    local mouseLocation = Vector2.new(screenPos.X, screenPos.Y)
                    local mouse = LocalPlayer:GetMouse()
                end
            end
        else
            if not AutoShootActive then
                CurrentTarget = nil
                LockEnabled = false
            end
        end
    end

    if ESPEnabled then
        local currentGunDrop = CachedGunDrop

        if currentGunDrop and currentGunDrop.Parent then
            if FallbackSheriffMarker then
                FallbackSheriffMarker:Destroy()
                FallbackSheriffMarker = nil
            end

            if GunDropMarker ~= currentGunDrop then
                ClearGunDropVisuals()
                CreateGunDropVisuals(currentGunDrop)
            end

            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local myPos = LocalPlayer.Character.HumanoidRootPart.Position
                local gunPos = currentGunDrop:IsA("Model") and currentGunDrop:GetPivot().Position or currentGunDrop.Position
                local distance = math.round((gunPos - myPos).Magnitude)

                if GunDropLabel then
                    GunDropLabel.Text = string.format("[Gun] %d studs", distance)
                end
            else
                if GunDropLabel then GunDropLabel.Text = "[Gun]" end
            end
            
            if GunDropHighlight and not GunDropHighlight.Enabled then GunDropHighlight.Enabled = true end
            if GunDropLabel and not GunDropLabel.Parent.Enabled then GunDropLabel.Parent.Enabled = true end
        else
            ClearGunDropVisuals()

            local murdererAlive = GetMurdererPlayer()
            if murdererAlive then
                local sheriff = GetSheriff()
                if sheriff then
                    HadSheriffBefore = true
                    local root = sheriff.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        LastSheriffPos = root.Position
                    end
                    if FallbackSheriffMarker then
                        FallbackSheriffMarker:Destroy()
                        FallbackSheriffMarker = nil
                    end
                else
                    if HadSheriffBefore and LastSheriffPos then
                        CreateFallbackMarker(LastSheriffPos)
                    end
                    HadSheriffBefore = false
                end
            else
                if FallbackSheriffMarker then
                    FallbackSheriffMarker:Destroy()
                    FallbackSheriffMarker = nil
                end
                HadSheriffBefore = false
            end
        end
    end
end)

